#!/usr/bin/env bash
# Installs Nginx on Ubuntu 16.04, starts the service, and sets a custom index page containing "Holberton School for the win!"

# Update package list
apt-get update -y

# Install Nginx silently
apt-get install -y nginx

# Create the index.html page with the required content
echo "Holberton School for the win!" > /var/www/html/index.html

# Start Nginx (use service or init.d if not running)
service nginx start || /etc/init.d/nginx start
